{
  "name": "galeria-black-diaz-oss",
  "version": "1.0.0",
  "description": "Um projeto educativo desenvolvido por Black Diaz OSS para pessoas que buscam recursos gratuitos pra seus perfis no GitHub",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "24"
